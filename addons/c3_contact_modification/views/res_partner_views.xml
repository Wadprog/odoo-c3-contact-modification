<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_gender" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.gender</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name' and @invisible='is_company']" position="attributes">
                <attribute name="placeholder">Last name first, then first name</attribute>
            </xpath>
            <xpath expr="//field[@name='function']" position="after">
                <field name="gender" invisible="is_company"/>
                <field name="date_of_birth" invisible="is_company"/>
            </xpath>
            <xpath expr="//page[@name='internal_notes']" position="after">
                <page name="c3_id_document" string="ID Document" invisible="is_company">
                    <group>
                        <field
                            name="c3_id_document"
                            filename="c3_id_document_filename"
                            widget="c3_id_document_binary"
                            options="{'accepted_file_extensions': '.jpg,.jpeg,.png', 'allowed_mime_type': 'image/jpeg,image/png'}"
                        />
                        <field name="c3_id_document_filename" invisible="1"/>
                    </group>
                </page>
                <page name="c3_contact_visits" string="Visits" invisible="is_company">
                    <group>
                        <field name="visit_ids" nolabel="1">
                            <list>
                                <field name="create_date"/>
                                <field name="visit_reason_id"/>
                                <field name="note"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
